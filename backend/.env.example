NODE_ENV=development
PORT=4000

# MongoDB
# Replace this with your MongoDB Atlas connection string (e.g., mongodb+srv://<username>:<password>@cluster.mongodb.net/rentify)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rentify

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173
